#!/usr/bin/env bash
# Simplified Universal System & Tool Updater - macOS Bash Version (Final Robust)
set -euo pipefail

# Configuration
DRY_RUN=false
VERBOSE=false
FORCE_RUN=false
SCRIPT_NAME="$(basename "$0")"
LOCK_FILE="/tmp/.${SCRIPT_NAME}_lock"
REPORT_DIR="$(mktemp -d "/tmp/${SCRIPT_NAME}_reports.XXXXXX")"
SKIP_COMMANDS=false
COMMANDS_FILE=""

resolve_script_path() {
    local path="$1"
    if [[ "$path" != /* && "$path" != *"/"* ]]; then
        path="$(command -v "$path" 2>/dev/null || echo "$path")"
    fi
    while [[ -L "$path" ]]; do
        local dir target
        dir="$(cd -P "$(dirname "$path")" && pwd)"
        target="$(readlink "$path")"
        [[ "$target" != /* ]] && target="$dir/$target"
        path="$target"
    done
    echo "$path"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]:-$0}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
COMMANDS_FILE="$SCRIPT_DIR/update-all.commands"
source "$SCRIPT_DIR/lib/pm-helpers.sh"

if [[ ! -d "$REPORT_DIR" ]]; then
    echo "Failed to create report directory. Exiting." >&2
    exit 1
fi

# Colors
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly RED='\033[0;31m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m'

# Status tracking
current_step=0
total_steps=0

# Cleanup on exit
cleanup() {
    local exit_code=$?
    [[ -f "$LOCK_FILE" ]] && rm -f "$LOCK_FILE"
    if [[ -n "${REPORT_DIR:-}" && -d "$REPORT_DIR" ]]; then
        rm -rf "$REPORT_DIR"
    fi
    if [[ $exit_code -ne 0 && $exit_code -ne 130 ]]; then
        echo -e "\n${RED}Script aborted (exit code: $exit_code)${NC}"
    fi
    exit $exit_code
}
trap cleanup EXIT INT TERM

# Utility functions
command_exists() { command -v "$1" >/dev/null 2>&1; }

commands_file_has_entries() {
    local file="$1"
    [[ -f "$file" ]] && grep -Eq '^[[:space:]]*[^#[:space:]]' "$file"
}

print_header() {
    echo -e "\n${YELLOW}=======================================================${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${YELLOW}=======================================================${NC}\n"
}

show_progress() {
    current_step=$((current_step + 1))
    echo -e "${BLUE}[$current_step/$total_steps] $1${NC}"
}

log_status() {
    local component="$1"
    local status="$2"
    [[ -d "$REPORT_DIR" ]] || return
    printf '%s\t%s\n' "$component" "$status" >> "$REPORT_DIR/status.log"
}

# Execute command with proper error handling and reporting
safe_execute() {
    local description="$1"
    shift
    if [[ "$DRY_RUN" = true ]]; then
        echo -e "${CYAN}[DRY RUN] Would execute: $*${NC}"
        log_status "$description" "🔍 Dry run"
        SAFE_EXECUTE_LAST_EXIT_CODE=0
        return 0
    fi

    [[ "$VERBOSE" = true ]] && echo -e "${CYAN}Executing: $*${NC}"

    local output exit_code
    local previous_errexit=0
    [[ $- == *e* ]] && previous_errexit=1

    set +e
    output=$("$@" 2>&1)
    exit_code=$?
    if [[ $previous_errexit -eq 1 ]]; then set -e; else set +e; fi

    if [[ $exit_code -eq 0 ]]; then
        log_status "$description" "✅ Success"
        [[ "$VERBOSE" = true ]] && echo -e "${GREEN}✅ $description completed${NC}"
    else
        log_status "$description" "❌ Failed (exit code: $exit_code)"
        echo -e "${RED}❌ $description failed with exit code $exit_code${NC}"
        local cmd_str="$*"
        echo -e "${CYAN}Command:${NC} $cmd_str"
        if [[ -n "$output" ]]; then
            while IFS= read -r line; do
                echo "[$cmd_str] $line"
            done <<< "$output"
        fi
    fi
    return $exit_code
}

acquire_lock() {
    if [[ -f "$LOCK_FILE" ]]; then
        local lock_pid
        lock_pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
        if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
            if [[ "$FORCE_RUN" = true ]]; then
                echo -e "${YELLOW}Warning: Forcibly removing existing lock file (PID: $lock_pid)${NC}"
                rm -f "$LOCK_FILE"
            else
                echo -e "${RED}Error: Another instance is already running (PID: $lock_pid)${NC}"
                exit 1
            fi
        else
            rm -f "$LOCK_FILE"
        fi
    fi
    echo "$$" > "$LOCK_FILE"
}

get_user_input() {
    local prompt="$1"
    local timeout="${2:-15}"
    local default="${3:-n}"
    echo -e "${BLUE}$prompt (y/n - timeout in ${timeout}s)${NC}"
    local input
    if read -r -t "$timeout" input 2>/dev/null; then
        case "$input" in
            [Yy]|[Yy][Ee][Ss]) return 0 ;;
            [Nn]|[Nn][Oo]|"") return 1 ;;
            *) [[ "$default" = "y" ]] ;;
        esac
    else
        echo -e "\nTimeout reached. Using default: $default"
        [[ "$default" = "y" ]]
    fi
}

# --- UPDATE FUNCTIONS ---

update_homebrew() {
    safe_execute "Homebrew update" brew update
    safe_execute "Homebrew upgrade" brew upgrade
    safe_execute "Homebrew cleanup" brew cleanup
}

update_mise_tools() {
    safe_execute "mise tool upgrades" mise upgrade --yes
    safe_execute "mise reshim" mise reshim
}

update_custom_commands() {
    local file="$COMMANDS_FILE"

    if [[ "$SKIP_COMMANDS" = true ]]; then
        log_status "custom commands" "⏭️ Skipped"
        return
    fi

    if ! commands_file_has_entries "$file"; then
        log_status "custom commands" "⏭️ No commands file"
        return
    fi

    local idxfile="$REPORT_DIR/commands.index"
    : > "$idxfile"

    local i=0
    local failures=0
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        [[ "$line" == \#* ]] && continue

        i=$((i + 1))
        local label
        label="command $(printf '%02d' "$i")"
        printf '%s\t%s\n' "$label" "$line" >> "$idxfile"

        if [[ "$DRY_RUN" = true ]]; then
            echo -e "${CYAN}[DRY RUN] Would execute: $line${NC}"
            log_status "$label" "🔍 Dry run"
            continue
        fi

        safe_execute "$label" bash -lc "$line"
        if [[ $? -ne 0 ]]; then
            failures=$((failures + 1))
        fi
    done < "$file"

    if [[ $failures -eq 0 ]]; then
        log_status "custom commands" "✅ Completed ($i)"
    else
        log_status "custom commands" "❌ Failed ($failures of $i)"
    fi
}

# --- Per-PM functions ---
# Each PM provides: pm_<name>_installed and pm_<name>_run.

pm_pipx_installed() { command_exists pipx; }
pm_pipx_run() {
    if pipx upgrade-all > "$REPORT_DIR/pipx.log" 2>&1; then
        parse_pipx_output < "$REPORT_DIR/pipx.log"
    else
        echo -e "${RED}⚠️ Pipx upgrade failed. Details:${NC}"
        cat "$REPORT_DIR/pipx.log"
        return 1
    fi
}

pm_npm_installed() { command_exists npm; }
pm_npm_run() {
    declare -A old_versions=()
    parse_npm_tree old_versions < <(npm list -g --depth=0 2>/dev/null)

    local -a packages=()
    readarray -t packages < <(map_to_latest old_versions npm)

    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "No global npm packages detected."
        return 0
    fi

    echo "Updating npm globals: ${packages[*]}"
    if npm install -g "${packages[@]}" > "$REPORT_DIR/npm_install.log" 2>&1; then
        declare -A new_versions=()
        parse_npm_tree new_versions < <(npm list -g --depth=0 2>/dev/null)
        print_version_diff old_versions new_versions
    else
        echo -e "${RED}⚠️ npm update failed. Details:${NC}"
        cat "$REPORT_DIR/npm_install.log"
        return 1
    fi
}

pm_bun_installed() { command_exists bun; }
pm_bun_run() {
    local workdir
    workdir="$(mktemp -d "/tmp/${SCRIPT_NAME}_bun.XXXXXX")"

    declare -A old_versions=()
    parse_bun_tree old_versions < <(cd "$workdir" && bun pm ls -g 2>/dev/null)

    local -a packages=()
    readarray -t packages < <(map_to_latest old_versions)

    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "No global Bun packages detected."
        rm -rf "$workdir"
        return 0
    fi

    echo "Updating Bun globals: ${packages[*]}"
    if (cd "$workdir" && bun add -g "${packages[@]}") > "$REPORT_DIR/bun_install.log" 2>&1; then
        declare -A new_versions=()
        parse_bun_tree new_versions < <(cd "$workdir" && bun pm ls -g 2>/dev/null)
        print_version_diff old_versions new_versions
    else
        echo -e "${RED}⚠️ Bun update failed. Details:${NC}"
        cat "$REPORT_DIR/bun_install.log"
        rm -rf "$workdir"
        return 1
    fi
    rm -rf "$workdir"
}

# --- PM orchestrator ---

# Canonical label mapping
declare -A PM_LABELS=(
    [pipx]="pipx packages"
    [npm]="npm global packages"
    [bun]="bun global packages"
)

# Known PM names — the orchestrator iterates over this list.
PM_NAMES=(pipx npm bun)

# Run a single PM in a subshell, reporting status via log_status.
update_pm() {
    local name="$1"
    local label="${PM_LABELS[$name]:-$name packages}"
    if ! "pm_${name}_installed"; then
        log_status "$label" "⏭️ Not installed"
        return
    fi
    if [[ "$DRY_RUN" = true ]]; then
        log_status "$label" "🔍 Dry run"
        return
    fi
    local exit_code
    set +e
    "pm_${name}_run"
    exit_code=$?
    set -e
    log_status "$label" "$([[ "$exit_code" -eq 0 ]] && printf '✅ Success' || printf '❌ Failed')"
}

# Update all known PMs in parallel.
update_global_packages() {
    local pids=()
    local pm
    for pm in "${PM_NAMES[@]}"; do
        update_pm "$pm" & pids+=($!)
    done

    if [[ ${#pids[@]} -gt 0 ]]; then
        echo "Waiting for package managers..."
        wait "${pids[@]}"
    fi
}


check_macos_updates() {
    if [[ "$DRY_RUN" = true ]]; then
        log_status "macOS Updates" "🔍 Dry run"
        return
    fi
    local updates_output
    if updates_output=$(softwareupdate -l 2>&1); then
        if echo "$updates_output" | grep -q "No new software available"; then
            log_status "macOS Updates" "✅ Up to date"
        else
            echo -e "${YELLOW}Available macOS updates:${NC}\n$updates_output"
            log_status "macOS Updates" "⚠️ Updates available"
        fi
    else
        log_status "macOS Updates" "❌ Check failed"
    fi
}

# --- Tool registry ---

TOOLS=(homebrew macos mise global_packages custom_commands)

declare -A TOOL_LABELS=(
    [homebrew]="Updating Homebrew"
    [macos]="Checking macOS System Updates"
    [mise]="Updating mise tools (Runtimes)"
    [global_packages]="Updating global packages (Bun, npm, Pipx)"
    [custom_commands]="Running custom commands"
)

declare -A TOOL_PHASES=(
    [homebrew]="phase1"
    [macos]="phase1"
    [mise]="phase1"
    [global_packages]="phase2"
    [custom_commands]="post"
)

tool_homebrew_enabled() { command_exists brew; }
tool_homebrew_run() { update_homebrew; }
tool_homebrew_components() {
    printf '%s\n' "Homebrew update" "Homebrew upgrade" "Homebrew cleanup"
}

tool_macos_enabled() { command_exists softwareupdate; }
tool_macos_run() { check_macos_updates; }
tool_macos_components() { printf '%s\n' "macOS Updates"; }

tool_mise_enabled() { command_exists mise; }
tool_mise_run() { update_mise_tools; }
tool_mise_components() { printf '%s\n' "mise tool upgrades" "mise reshim"; }

tool_global_packages_enabled() { return 0; }
tool_global_packages_run() { update_global_packages; }
tool_global_packages_components() {
    printf '%s\n' "pipx packages" "npm global packages" "bun global packages"
}

tool_custom_commands_enabled() {
    [[ "$SKIP_COMMANDS" = false ]] && commands_file_has_entries "$COMMANDS_FILE"
}
tool_custom_commands_run() { update_custom_commands; }
tool_custom_commands_disabled() {
    if [[ "$SKIP_COMMANDS" = true ]]; then
        log_status "custom commands" "⏭️ Skipped"
    else
        log_status "custom commands" "⏭️ No commands file"
    fi
}
tool_custom_commands_components() { printf '%s\n' "custom commands"; }

tool_is_enabled() { "tool_${1}_enabled"; }
tool_run() { "tool_${1}_run"; }
tool_phase() { printf '%s' "${TOOL_PHASES[$1]}"; }
tool_label() { printf '%s' "${TOOL_LABELS[$1]}"; }
tool_print_components() { "tool_${1}_components"; }
tool_handle_disabled() {
    local fn="tool_${1}_disabled"
    if declare -F "$fn" >/dev/null; then
        "$fn"
    fi
}

count_enabled_tools() {
    local tool count=0
    for tool in "${TOOLS[@]}"; do
        tool_is_enabled "$tool" && ((count++))
    done
    echo "$count"
}

run_parallel_phase() {
    local phase="$1"
    local wait_message="$2"
    local jobs=()
    local tool

    for tool in "${TOOLS[@]}"; do
        [[ "$(tool_phase "$tool")" == "$phase" ]] || continue
        tool_is_enabled "$tool" || continue
        show_progress "$(tool_label "$tool")"
        (tool_run "$tool") & jobs+=($!)
    done

    if [[ ${#jobs[@]} -gt 0 ]]; then
        echo -e "${BLUE}${wait_message}${NC}"
        wait "${jobs[@]}"
    fi
}

run_serial_phase() {
    local phase="$1"
    local tool

    for tool in "${TOOLS[@]}"; do
        [[ "$(tool_phase "$tool")" == "$phase" ]] || continue
        if tool_is_enabled "$tool"; then
            show_progress "$(tool_label "$tool")"
            tool_run "$tool"
        else
            tool_handle_disabled "$tool"
        fi
    done
}

generate_summary() {
    declare -A status=()
    local tool component

    if [[ -f "$REPORT_DIR/status.log" ]]; then
        while IFS=$'\t' read -r component state; do
            [[ -z "${component// }" ]] && continue
            status["$component"]="$state"
        done < "$REPORT_DIR/status.log"
    fi

    echo -e "\n${YELLOW}=======================================================${NC}"
    echo -e "${GREEN}Update Summary Report${NC}"
    echo -e "${YELLOW}=======================================================${NC}\n"

    for tool in "${TOOLS[@]}"; do
        while IFS= read -r component; do
            [[ -z "${component:-}" ]] && continue
            if [[ -n "${status[$component]+_}" ]]; then
                printf "${BLUE}%-45s${NC} %s\n" "$component:" "${status[$component]}"
            fi
        done < <(tool_print_components "$tool")
    done

    if [[ -f "$REPORT_DIR/commands.index" ]]; then
        echo -e "\n${GREEN}Custom commands${NC}"
        while IFS=$'\t' read -r label cmd; do
            [[ -z "${label:-}" ]] && continue
            echo -e "${CYAN}- $cmd${NC}"
        done < "$REPORT_DIR/commands.index"
    fi

    echo -e "\n${CYAN}Completed on: $(date)${NC}"
}

# --- MAIN EXECUTION ---

main() {
    set +e
    echo -e "${CYAN}Starting Universal System & Tool Updater (Final Robust)...${NC}"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run) DRY_RUN=true ;;
            --verbose) VERBOSE=true ;;
            --force) FORCE_RUN=true ;;
            --commands-file)
                shift
                [[ $# -gt 0 ]] || { echo "--commands-file requires a path" >&2; exit 1; }
                COMMANDS_FILE="$1"
                ;;
            --skip-commands) SKIP_COMMANDS=true ;;
            --help|-h)
                cat <<EOF
Usage: $SCRIPT_NAME [options]

Options:
  --dry-run            Print commands without executing
  --verbose            Print commands as they run
  --force              Force run even if lock exists
  --commands-file PATH Use a custom commands file (default: $SCRIPT_DIR/update-all.commands)
  --skip-commands       Disable running custom commands
  --help, -h           Show this help
EOF
                exit 0
                ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
        shift
    done

    # 1. SETUP PHASE
    acquire_lock
    cd "$HOME"
    export PATH="$HOME/.bun/bin:$HOME/.local/share/mise/shims:$PATH"
    if command_exists mise; then eval "$(mise activate bash)"; fi

    # Calculate steps from the registry after PATH/setup is complete.
    total_steps="$(count_enabled_tools)"

    run_parallel_phase "phase1" "...Waiting for System & Runtime updates to finish..."
    run_parallel_phase "phase2" "...Waiting for Package updates to finish..."
    run_serial_phase "post"

    generate_summary
}

[[ "${DEBUG:-}" == "true" ]] && set -x
main "$@"
