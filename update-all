#!/usr/bin/env bash
# Simplified Universal System & Tool Updater - macOS Bash Version (Final Robust)
set -euo pipefail

# Configuration
DRY_RUN=false
VERBOSE=false
FORCE_RUN=false
SCRIPT_NAME="$(basename "$0")"
LOCK_FILE="/tmp/.${SCRIPT_NAME}_lock"
REPORT_DIR="$(mktemp -d "/tmp/${SCRIPT_NAME}_reports.XXXXXX")"
SKIP_COMMANDS=false
COMMANDS_FILE=""

resolve_script_path() {
    local path="$1"
    if [[ "$path" != /* && "$path" != *"/"* ]]; then
        path="$(command -v "$path" 2>/dev/null || echo "$path")"
    fi
    while [[ -L "$path" ]]; do
        local dir target
        dir="$(cd -P "$(dirname "$path")" && pwd)"
        target="$(readlink "$path")"
        [[ "$target" != /* ]] && target="$dir/$target"
        path="$target"
    done
    echo "$path"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]:-$0}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
COMMANDS_FILE="$SCRIPT_DIR/update-all.commands"
source "$SCRIPT_DIR/lib/global-packages.sh"
source "$SCRIPT_DIR/lib/custom-commands.sh"
source "$SCRIPT_DIR/lib/tool-runner.sh"

if [[ ! -d "$REPORT_DIR" ]]; then
    echo "Failed to create report directory. Exiting." >&2
    exit 1
fi

# Colors
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly RED='\033[0;31m'
readonly CYAN='\033[0;36m'
readonly NC='\033[0m'

# Cleanup on exit
cleanup() {
    local exit_code=$?
    [[ -f "$LOCK_FILE" ]] && rm -f "$LOCK_FILE"
    if [[ -n "${REPORT_DIR:-}" && -d "$REPORT_DIR" ]]; then
        rm -rf "$REPORT_DIR"
    fi
    if [[ $exit_code -ne 0 && $exit_code -ne 130 ]]; then
        echo -e "\n${RED}Script aborted (exit code: $exit_code)${NC}"
    fi
    exit $exit_code
}
trap cleanup EXIT INT TERM

# Utility functions
command_exists() { command -v "$1" >/dev/null 2>&1; }

print_header() {
    echo -e "\n${YELLOW}=======================================================${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${YELLOW}=======================================================${NC}\n"
}

show_progress() {
    local current="$1"
    local total="$2"
    local label="$3"
    echo -e "${BLUE}[$current/$total] $label${NC}"
}

log_status() {
    local component="$1"
    local status="$2"
    [[ -d "$REPORT_DIR" ]] || return
    printf '%s\t%s\n' "$component" "$status" >> "$REPORT_DIR/status.log"
}

# Execute command with proper error handling and reporting
safe_execute() {
    local description="$1"
    shift
    if [[ "$DRY_RUN" = true ]]; then
        echo -e "${CYAN}[DRY RUN] Would execute: $*${NC}"
        log_status "$description" "🔍 Dry run"
        SAFE_EXECUTE_LAST_EXIT_CODE=0
        return 0
    fi

    [[ "$VERBOSE" = true ]] && echo -e "${CYAN}Executing: $*${NC}"

    local output exit_code
    local previous_errexit=0
    [[ $- == *e* ]] && previous_errexit=1

    set +e
    output=$("$@" 2>&1)
    exit_code=$?
    if [[ $previous_errexit -eq 1 ]]; then set -e; else set +e; fi

    if [[ $exit_code -eq 0 ]]; then
        log_status "$description" "✅ Success"
        [[ "$VERBOSE" = true ]] && echo -e "${GREEN}✅ $description completed${NC}"
    else
        log_status "$description" "❌ Failed (exit code: $exit_code)"
        echo -e "${RED}❌ $description failed with exit code $exit_code${NC}"
        local cmd_str="$*"
        echo -e "${CYAN}Command:${NC} $cmd_str"
        if [[ -n "$output" ]]; then
            while IFS= read -r line; do
                echo "[$cmd_str] $line"
            done <<< "$output"
        fi
    fi
    return $exit_code
}

acquire_lock() {
    if [[ -f "$LOCK_FILE" ]]; then
        local lock_pid
        lock_pid=$(cat "$LOCK_FILE" 2>/dev/null || echo "")
        if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
            if [[ "$FORCE_RUN" = true ]]; then
                echo -e "${YELLOW}Warning: Forcibly removing existing lock file (PID: $lock_pid)${NC}"
                rm -f "$LOCK_FILE"
            else
                echo -e "${RED}Error: Another instance is already running (PID: $lock_pid)${NC}"
                exit 1
            fi
        else
            rm -f "$LOCK_FILE"
        fi
    fi
    echo "$$" > "$LOCK_FILE"
}

get_user_input() {
    local prompt="$1"
    local timeout="${2:-15}"
    local default="${3:-n}"
    echo -e "${BLUE}$prompt (y/n - timeout in ${timeout}s)${NC}"
    local input
    if read -r -t "$timeout" input 2>/dev/null; then
        case "$input" in
            [Yy]|[Yy][Ee][Ss]) return 0 ;;
            [Nn]|[Nn][Oo]|"") return 1 ;;
            *) [[ "$default" = "y" ]] ;;
        esac
    else
        echo -e "\nTimeout reached. Using default: $default"
        [[ "$default" = "y" ]]
    fi
}

# --- UPDATE FUNCTIONS ---

update_homebrew() {
    safe_execute "Homebrew update" brew update
    safe_execute "Homebrew upgrade" brew upgrade
    safe_execute "Homebrew cleanup" brew cleanup
}

update_mise_tools() {
    safe_execute "mise tool upgrades" mise upgrade --yes
    safe_execute "mise reshim" mise reshim
}

run_custom_command() {
    local label="$1"
    local line="$2"
    safe_execute "$label" bash -lc "$line"
}

update_custom_commands() {
    declare -A result=()
    custom_commands_run result "$COMMANDS_FILE" "$REPORT_DIR" "$DRY_RUN" log_status run_custom_command
}

update_global_packages() {
    declare -A result=()
    global_packages_run result "$REPORT_DIR" "$DRY_RUN" log_status
}


check_macos_updates() {
    if [[ "$DRY_RUN" = true ]]; then
        log_status "macOS Updates" "🔍 Dry run"
        return
    fi
    local updates_output
    if updates_output=$(softwareupdate -l 2>&1); then
        if echo "$updates_output" | grep -q "No new software available"; then
            log_status "macOS Updates" "✅ Up to date"
        else
            echo -e "${YELLOW}Available macOS updates:${NC}\n$updates_output"
            log_status "macOS Updates" "⚠️ Updates available"
        fi
    else
        log_status "macOS Updates" "❌ Check failed"
    fi
}

# --- Tool runner configuration ---

homebrew_tool_enabled() { command_exists brew; }
homebrew_tool_components() {
    printf '%s\n' "Homebrew update" "Homebrew upgrade" "Homebrew cleanup"
}

macos_tool_enabled() { command_exists softwareupdate; }
macos_tool_components() { printf '%s\n' "macOS Updates"; }

mise_tool_enabled() { command_exists mise; }
mise_tool_components() { printf '%s\n' "mise tool upgrades" "mise reshim"; }

global_packages_tool_enabled() { return 0; }
global_packages_tool_components() {
    printf '%s\n' "pipx packages" "npm global packages" "bun global packages"
}

custom_commands_tool_enabled() {
    custom_commands_should_run "$SKIP_COMMANDS" "$COMMANDS_FILE"
}
custom_commands_tool_disabled() {
    custom_commands_handle_disabled "$SKIP_COMMANDS" log_status
}
custom_commands_tool_components() { printf '%s\n' "custom commands"; }

configure_tool_runner() {
    tool_runner_reset
    tool_runner_define_phase "phase1" "parallel" "...Waiting for System & Runtime updates to finish..."
    tool_runner_define_phase "phase2" "parallel" "...Waiting for Package updates to finish..."
    tool_runner_define_phase "post" "serial"

    tool_runner_register "homebrew" "phase1" "Updating Homebrew" \
        homebrew_tool_enabled update_homebrew homebrew_tool_components
    tool_runner_register "macos" "phase1" "Checking macOS System Updates" \
        macos_tool_enabled check_macos_updates macos_tool_components
    tool_runner_register "mise" "phase1" "Updating mise tools (Runtimes)" \
        mise_tool_enabled update_mise_tools mise_tool_components
    tool_runner_register "global_packages" "phase2" "Updating global packages (Bun, npm, Pipx)" \
        global_packages_tool_enabled update_global_packages global_packages_tool_components
    tool_runner_register "custom_commands" "post" "Running custom commands" \
        custom_commands_tool_enabled update_custom_commands custom_commands_tool_components custom_commands_tool_disabled
}

# --- MAIN EXECUTION ---

main() {
    set +e
    echo -e "${CYAN}Starting Universal System & Tool Updater (Final Robust)...${NC}"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --dry-run) DRY_RUN=true ;;
            --verbose) VERBOSE=true ;;
            --force) FORCE_RUN=true ;;
            --commands-file)
                shift
                [[ $# -gt 0 ]] || { echo "--commands-file requires a path" >&2; exit 1; }
                COMMANDS_FILE="$1"
                ;;
            --skip-commands) SKIP_COMMANDS=true ;;
            --help|-h)
                cat <<EOF
Usage: $SCRIPT_NAME [options]

Options:
  --dry-run            Print commands without executing
  --verbose            Print commands as they run
  --force              Force run even if lock exists
  --commands-file PATH Use a custom commands file (default: $SCRIPT_DIR/update-all.commands)
  --skip-commands       Disable running custom commands
  --help, -h           Show this help
EOF
                exit 0
                ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
        shift
    done

    # 1. SETUP PHASE
    acquire_lock
    cd "$HOME"
    export PATH="$HOME/.bun/bin:$HOME/.local/share/mise/shims:$PATH"
    if command_exists mise; then eval "$(mise activate bash)"; fi

    configure_tool_runner
    tool_runner_execute "$REPORT_DIR" show_progress
}

[[ "${DEBUG:-}" == "true" ]] && set -x
main "$@"
